A = [
    [2, 1],
    [0, 3]
]

B = [
    [4, 5],
    [7, 1]
]

resultado  =[]
for i in range(2):
    fila = []
    for j in range(2):
        fila += [A[i][j] + B[i][j]]
    resultado+= [fila]
print(resultado)